# ─── Database ───────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_portal?schema=public"

# ─── Auth ───────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-before-production"

# ─── App ────────────────────────────────────────────────────────────────────
# REQUIRED in production. Use your public Railway URL, e.g. https://your-app.up.railway.app
APP_URL="http://localhost:3000"

# ─── Cron security ──────────────────────────────────────────────────────────
# REQUIRED in production. Cron routes reject requests without this.
# Sent as header: x-cron-secret: YOUR_VALUE  (by cron-job.org or Railway cron)
CRON_SECRET="change-me-to-random-string"

# ─── Job APIs (free tiers) ──────────────────────────────────────────────────
# Adzuna: free 250 calls/day — https://developer.adzuna.com
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# JSearch via RapidAPI: free 200/month — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Aggregates LinkedIn, Indeed, Glassdoor, ZipRecruiter in one call
JSEARCH_API_KEY=""

# ─── Google / Gmail OAuth (optional — enables auto-verification) ─────────────
# 1. https://console.cloud.google.com → New project → Enable Gmail API
# 2. Create OAuth 2.0 Web Application credentials
# 3. Redirect URI: https://YOUR_APP_URL/api/gmail/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Apify (add later when free APIs aren't enough) ─────────────────────────
APIFY_API_TOKEN=""

# ─── Resume Builder (optional N8N webhook) ───────────────────────────────────
# If set, clicking "Send to Resume Builder" will POST a payload to this URL
# Leave empty to use clipboard-only mode
N8N_RESUME_WEBHOOK_URL=""

# ─── First production admin bootstrap ───────────────────────────────────────
# Set these temporarily, run `npm run db:bootstrap-admin`, then rotate/remove ADMIN_PASSWORD.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-to-a-long-password"
ADMIN_NAME="Admin"
